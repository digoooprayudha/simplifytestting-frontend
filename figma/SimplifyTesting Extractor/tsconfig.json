{
    "compilerOptions": {
        "target": "es6",
        "lib": [
            "es6",
            "es2017",
            "dom"
        ],
        "typeRoots": [
            "./node_modules/@types",
            "./node_modules/@figma"
        ],
        "allowJs": true,
        "checkJs": false,
        "skipLibCheck": true,
        "esModuleInterop": true,
        "isolatedModules": true,
        "strict": true,
        "moduleResolution": "node"
    }
}